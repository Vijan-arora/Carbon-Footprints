{
  "name": "carbontrace",
  "version": "1.0.0",
  "description": "Carbon Footprint Awareness Platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && nodemon index.js",
    "client": "cd client && npm run dev",
    "setup": "npm install && cd client && npm install && cd ../server && npm install && npx prisma migrate dev && npx prisma db seed",
    "build": "cd client && npm run build"
  },
  "keywords": ["carbon", "footprint", "sustainability", "environment"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
